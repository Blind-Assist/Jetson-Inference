[Unit]
Description=Blind Assist Inference Service
After=multi-user.target sound.target
Wants=sound.target

[Service]
Type=simple
User=blind
WorkingDirectory=/home/blind/internvl3

Environment=HOME=/home/blind
Environment=HF_HOME=/home/blind/.cache/huggingface
Environment=PYTHONUNBUFFERED=1

ExecStartPre=/bin/sleep 20
ExecStart=/home/blind/internvl3/myenv/bin/python -u /home/blind/internvl3/InternVL/internvl_chat/webcam_audio.py

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
